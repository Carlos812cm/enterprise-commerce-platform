# .NET container images
DOTNET_SDK_VERSION=10.0.301
DOTNET_RUNTIME_VERSION=10.0.9

# Application
COMMERCE_API_PORT=5000

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=commerce
POSTGRES_PASSWORD=commerce_dev_password
POSTGRES_DB=commerce

# Redis
REDIS_PORT=16379

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=commerce
RABBITMQ_DEFAULT_PASS=commerce_dev_password

# Keycloak
KEYCLOAK_PORT=8080
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=admin

# Observability images
OTEL_COLLECTOR_VERSION=0.156.0
PROMETHEUS_VERSION=v3.13.0
TEMPO_VERSION=3.0.2
GRAFANA_VERSION=13.1.0

# Observability ports
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
GRAFANA_PORT=3000

# Grafana local credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=commerce_grafana_dev_password